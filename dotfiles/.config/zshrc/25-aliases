# -----------------------------------------------------
# ALIASES
# -----------------------------------------------------

# -----------------------------------------------------
# General
# -----------------------------------------------------
alias ..='cd ..'
alias c='clear'
alias nf='fastfetch'
alias pf='fastfetch'
alias ff='fastfetch'
alias ls='eza -a --icons=always'
alias ll='eza -al --icons=always'
alias lt='eza -a --tree --level=1 --icons=always'
alias shutdown='~/.config/dotfiles/scripts/power -p'
alias v='$EDITOR'
alias vim='$EDITOR'
alias wifi='nmtui'
alias arch-cleanup='~/.config/dotfiles/scripts/arch/cleanup.sh'
alias apps='~/.config/dotfiles/bin/apps'
alias screenshot='~/.config/dotfiles/bin/screenshot'
alias updates='~/.config/dotfiles/scripts/install-system-updates'
alias filemanager='~/.config/dotfiles/settings/filemanager'
alias autostart='~/.config/dotfiles/scripts/autostart'
alias lock='~/.config/dotfiles/scripts/power -l'
alias clock='tty-clock'
alias system='~/.config/dotfiles/settings/systemmonitor'
alias quick='~/.config/dotfiles/bin/quicklinks'
alias wallpaper='~/.config/dotfiles/bin/wallpaper'

# -----------------------------------------------------
# Dotfiles Apps
# -----------------------------------------------------
alias wallpaper='qs -p ~/.config/quickshell/wallpaper-picker.qml &'
alias sudo='sudo -A'

# -----------------------------------------------------
# Git
# -----------------------------------------------------
alias gs="git status"
alias ga="git add"
alias gc="git commit -m"
alias gp="git push"
alias gpl="git pull"
alias gst="git stash"
alias gsp="git stash; git pull"
alias gfo="git fetch origin"
alias gcheck="git checkout"
alias gcredential="git config credential.helper store"

# -----------------------------------------------------
# Scripts
# -----------------------------------------------------
alias ascii='~/.config/dotfiles/scripts/ascii-header'

# -----------------------------------------------------
# System
# -----------------------------------------------------
alias update-grub='sudo grub-mkconfig -o /boot/grub/grub.cfg'

